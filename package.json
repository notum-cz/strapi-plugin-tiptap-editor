{
  "version": "1.0.3-rc.1",
  "keywords": [
    "strapi",
    "plugin",
    "tiptap",
    "editor",
    "rich-text",
    "wysiwyg"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@strapi/design-system": "2.2.0",
    "@strapi/icons": "2.2.0",
    "react-intl": "^8.1.3"
  },
  "devDependencies": {
    "@strapi/sdk-plugin": "^5.4.0",
    "@strapi/strapi": "5.39.0",
    "@strapi/typescript-utils": "5.39.0",
    "@tiptap/core": "3.20.1",
    "@tiptap/extension-color": "3.20.1",
    "@tiptap/extension-document": "3.20.1",
    "@tiptap/extension-heading": "3.20.1",
    "@tiptap/extension-highlight": "3.20.1",
    "@tiptap/extension-image": "3.20.1",
    "@tiptap/extension-paragraph": "3.20.1",
    "@tiptap/extension-subscript": "3.20.1",
    "@tiptap/extension-superscript": "3.20.1",
    "@tiptap/extension-table": "3.20.1",
    "@tiptap/extension-text": "3.20.1",
    "@tiptap/extension-text-align": "3.20.1",
    "@tiptap/extension-text-style": "3.20.1",
    "@tiptap/extension-underline": "3.20.1",
    "@tiptap/extensions": "3.20.1",
    "@tiptap/pm": "3.20.1",
    "@tiptap/react": "3.20.1",
    "@tiptap/starter-kit": "3.20.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "styled-components": "6.3.11",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@strapi/sdk-plugin": "^5.4.0",
    "@strapi/strapi": "^5.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.9"
  },
  "strapi": {
    "kind": "plugin",
    "name": "tiptap-editor",
    "displayName": "Tiptap Editor",
    "description": "Customizable Tip Tap Editor"
  },
  "name": "@notum-cz/strapi-plugin-tiptap-editor",
  "description": "Customizable Tip Tap Editor",
  "license": "MIT",
  "author": "Notum Technologies s.r.o. <sales@notum.cz> (https://notum.tech)",
  "maintainers": [
    "Notum Technologies s.r.o. <sales@notum.cz>",
    "Dominik Juriga <dominik.juriga@notum.cz>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notum-cz/strapi-plugin-tiptap-editor.git"
  },
  "bugs": {
    "url": "https://github.com/notum-cz/strapi-plugin-tiptap-editor/issues"
  },
  "homepage": "https://github.com/notum-cz/strapi-plugin-tiptap-editor#readme"
}
